<odoo>

    <!-- FIXED LIST VIEW -->
    <record id="view_hotel_booking_list" model="ir.ui.view">
        <field name="name">hotel.booking.list</field>
        <field name="model">hotel.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="customer_name"/>
                <field name="customer_id"/>
                <field name="room_id"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="total_price"/>
            </list>
        </field>
    </record>

    <!-- FIXED FORM VIEW -->
    <record id="view_hotel_booking_form" model="ir.ui.view">
        <field name="name">hotel.booking.form</field>
        <field name="model">hotel.booking</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="customer_name"/>
                        <field name="customer_id"/>
                        <field name="room_id"/>
                        <field name="check_in"/>
                        <field name="check_out"/>
                        <field name="total_price" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- FIXED ACTION -->
    <record id="action_hotel_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">hotel.booking</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
